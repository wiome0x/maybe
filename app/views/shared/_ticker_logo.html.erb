<%# locals: (ticker:, size: "w-9 h-9") %>
<%
  local_path = "stocks/#{ticker.upcase}.png"
  has_local = (Rails.application.assets_manifest.assets[local_path].present? rescue false)
  initial = ticker.first&.upcase || "?"
  colors = %w[#3B82F6 #10B981 #F59E0B #EF4444 #8B5CF6 #EC4899 #14B8A6 #F97316 #6366F1 #84CC16]
  bg = colors[ticker.bytes.sum % colors.length]
%>

<% if has_local %>
  <%= image_tag local_path, class: "#{size} rounded-full object-cover", loading: "lazy", alt: ticker %>
<% else %>
  <div class="<%= size %> rounded-full flex items-center justify-center" style="background-color:<%= bg %>;position:relative;overflow:hidden">
    <span class="text-white font-bold text-xs"><%= initial %></span>
  </div>
<% end %>
