<%# locals: (account:, api_key: nil) %>

<div class="space-y-4">
  <p class="text-sm text-secondary">
    Connect your Binance account to automatically sync your crypto holdings and trade history.
    Your API credentials are encrypted and stored securely.
  </p>

  <%= styled_form_with url: broker_connections_path,
                       method: :post,
                       data: { turbo: false },
                       class: "space-y-4" do |form| %>
    <%= hidden_field_tag "broker_connection[account_id]", account.id %>

    <div class="form-field">
      <div class="form-field__header">
        <label class="form-field__label" for="broker_connection_api_key">API Key</label>
      </div>
      <input type="text"
             id="broker_connection_api_key"
             name="broker_connection[api_key]"
             value="<%= api_key %>"
             placeholder="Enter your Binance API key"
             class="form-field__input"
             autocomplete="off"
             required />
    </div>

    <div class="form-field">
      <div class="form-field__header">
        <label class="form-field__label" for="broker_connection_api_secret">API Secret</label>
      </div>
      <input type="password"
             id="broker_connection_api_secret"
             name="broker_connection[api_secret]"
             placeholder="Enter your Binance API secret"
             class="form-field__input"
             autocomplete="off"
             required />
    </div>

    <div class="flex flex-col gap-2">
      <button type="submit"
              class="flex items-center justify-center gap-2 w-full rounded-lg bg-surface px-4 py-2.5 text-sm font-medium text-white hover:bg-surface-hover transition-colors">
        <%= icon("link-2", size: "sm") %>
        Connect Binance (optional)
      </button>

      <%= link_to "Skip for now",
                  account_path(account),
                  class: "flex items-center justify-center w-full rounded-lg border border-primary px-4 py-2.5 text-sm text-primary hover:bg-container-inset transition-colors" %>
    </div>
  <% end %>
</div>
