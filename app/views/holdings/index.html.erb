<%= turbo_frame_tag dom_id(@account, "holdings") do %>
  <div class="bg-container space-y-4 p-5 rounded-xl shadow-border-xs">
    <div class="flex items-center justify-between">
      <%= tag.h2 t(".holdings"), class: "font-medium text-lg" %>
      <%= link_to new_trade_path(account_id: @account.id),
                  id: dom_id(@account, "new_trade"),
                  data: { turbo_frame: :modal },
                  class: "flex gap-1 font-medium items-center bg-gray-50 text-primary p-2 rounded-lg" do %>
        <span class="text-primary">
          <%= icon("plus", color: "current") %>
        </span>
        <%= tag.span t(".new_holding"), class: "text-sm" %>
      <% end %>
    </div>

    <% stock_holdings = @account.current_holdings.reject { |h| h.ticker.include?(".") } %>

    <div class="bg-container-inset rounded-xl p-1">
      <div class="grid grid-cols-12 items-center uppercase text-xs font-medium text-secondary px-4 py-2">
        <%= tag.p t(".name"), class: "col-span-4" %>
        <%= tag.p t(".weight"), class: "col-span-2 justify-self-end" %>
        <%= tag.p t(".average_cost"), class: "col-span-2 justify-self-end" %>
        <%= tag.p t(".holdings"), class: "col-span-2 justify-self-end" %>
        <%= tag.p t(".return"), class: "col-span-2 justify-self-end" %>
      </div>

      <div class="bg-container rounded-lg shadow-border-xs">
        <%= render "holdings/cash", account: @account %>
        <%= render "shared/ruler" %>

        <% if stock_holdings.any? %>
          <%= render partial: "holdings/holding", collection: stock_holdings, spacer_template: "shared/ruler" %>
        <% end %>
      </div>
    </div>

    <% chart_holdings = stock_holdings.select { |h| h.weight.present? && h.weight > 0 } %>
    <% if chart_holdings.any? %>
      <%
        cash_weight = @account.balance.zero? ? 0 : (@account.cash_balance / @account.balance * 100).round(1)
        pie_data = []
        pie_data << { label: "Cash", value: cash_weight } if cash_weight > 0
        chart_holdings.each { |h| pie_data << { label: h.ticker, value: h.weight.round(1) } }
      %>
      <div class="bg-container-inset rounded-xl p-4"
           data-controller="holdings-pie"
           data-holdings-pie-data-value="<%= pie_data.to_json %>">
        <h3 class="text-xs font-medium text-secondary uppercase mb-3">Portfolio Allocation</h3>
        <div data-holdings-pie-target="canvas" class="flex items-center justify-center"></div>
      </div>
    <% end %>
  </div>
<% end %>
