<div class="space-y-4 pb-20">
  <header class="rounded-xl border border-alpha-black-100 bg-container shadow-border-xs overflow-hidden">
    <div class="px-4 py-4 md:px-5 md:py-5 bg-[linear-gradient(135deg,rgba(15,23,42,0.02)_0%,rgba(59,130,246,0.05)_52%,rgba(255,255,255,0)_100%)]">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="space-y-3">
          <div class="space-y-1">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-secondary"><%= t(".news_label") %></p>
            <h1 class="text-xl font-semibold tracking-[-0.02em] text-primary md:text-2xl"><%= t(".title") %></h1>
          </div>
          <p class="max-w-3xl text-sm leading-6 text-secondary"><%= t(".news_description") %></p>
        </div>

        <div class="grid grid-cols-2 gap-2 md:min-w-[220px]">
          <div class="rounded-lg border border-alpha-black-100 bg-white/60 px-3 py-2">
            <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-secondary"><%= t(".summary_feed_label") %></p>
            <p class="mt-1 text-sm font-semibold text-primary">CNBC + Seeking Alpha + SEC + Bloomberg + MarketWatch + Fed</p>
          </div>
          <div class="rounded-lg border border-alpha-black-100 bg-white/60 px-3 py-2">
            <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-secondary"><%= t(".summary_items_label") %></p>
            <p class="mt-1 text-sm font-semibold text-primary"><%= @market_news.size %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-alpha-black-100 px-4 py-3 md:px-5">
      <%= render "markets/stocks_section_nav" %>
    </div>
  </header>

  <%= render "markets/news_feed" %>
</div>
