<div class="space-y-4 pb-20">
  <header class="space-y-3">
    <h1 class="text-xl font-medium text-primary"><%= t(".title") %></h1>
    <%= render "stocks_section_nav" %>
  </header>

  <div class="bg-container rounded-xl shadow-border-xs p-4 space-y-4">
    <p class="text-sm text-secondary"><%= t(".description") %></p>

    <div class="rounded-lg overflow-hidden border border-primary h-[720px] bg-surface-inset">
      <div class="tradingview-widget-container h-full">
        <div class="tradingview-widget-container__widget h-full"></div>
        <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-stock-heatmap.js" async>
          {
            "exchanges": [],
            "dataSource": "SPX500",
            "grouping": "sector",
            "blockSize": "market_cap_basic",
            "blockColor": "change",
            "locale": "en",
            "symbolUrl": "",
            "colorTheme": "dark",
            "hasTopBar": true,
            "isDataSetEnabled": true,
            "isZoomEnabled": true,
            "hasSymbolTooltip": true,
            "isMonoSize": false,
            "width": "100%",
            "height": "100%"
          }
        </script>
      </div>
    </div>
  </div>
</div>
