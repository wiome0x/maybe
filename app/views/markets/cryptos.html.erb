<div class="space-y-4 pb-20">
  <header class="flex justify-between items-center">
    <h1 class="text-xl font-medium text-primary"><%= t(".title") %></h1>
    <%= render DS::Link.new(text: t(".manage"), href: settings_watchlist_path, variant: "ghost", icon: "settings") %>
  </header>

  <% if @quotes.any? %>
    <%# Wrap the entire list in binance-ticker so one WebSocket covers all symbols %>
    <div class="space-y-2"
         data-controller="binance-ticker"
         data-binance-ticker-symbols-value="<%= @quotes.map(&:symbol).to_json %>">
      <% @quotes.each do |quote| %>
        <div class="bg-container rounded-xl shadow-border-xs"
             data-controller="market-chart"
             data-market-chart-symbol-value="BINANCE:<%= quote.symbol %>USDT"
             data-market-chart-name-value="<%= quote.symbol %> - <%= quote.name %>">

          <div class="p-4 flex items-center gap-4">
            <%# Logo %>
            <div class="w-11 h-11 shrink-0 rounded-full bg-container-inset flex items-center justify-center overflow-hidden">
              <% if quote.logo_url.present? %>
                <%= image_tag quote.logo_url, class: "w-full h-full object-cover", loading: "lazy", alt: quote.symbol %>
              <% else %>
                <span class="text-sm font-bold text-secondary"><%= quote.symbol.first %></span>
              <% end %>
            </div>

            <%# Name + Ticker %>
            <div class="w-24 shrink-0">
              <p class="font-medium text-primary text-sm truncate"><%= quote.name %></p>
              <p class="text-xs text-secondary"><%= quote.symbol %></p>
            </div>

            <%# Data Grid - middle area %>
            <div class="flex-1 min-w-0 hidden md:grid grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-1 text-xs">
              <div>
                <p class="text-secondary"><%= t(".change_label") %></p>
                <%# change target: updated in real-time by binance-ticker controller %>
                <p class="font-medium <%= quote.change_positive? ? trend_up_color_class : trend_down_color_class %>"
                   data-binance-ticker-target="change"
                   data-symbol="<%= quote.symbol %>"><%= quote.change_formatted %></p>
              </div>
              <div>
                <p class="text-secondary"><%= t(".volume_label") %></p>
                <p class="font-medium text-primary"><%= quote.volume_formatted %></p>
              </div>
              <div>
                <p class="text-secondary"><%= t(".market_cap_label") %></p>
                <p class="font-medium text-primary"><%= quote.market_cap_formatted %></p>
              </div>
              <div>
                <p class="text-secondary"><%= t(".high_low_label") %></p>
                <p class="font-medium text-primary">$<%= quote.high_formatted %> / $<%= quote.low_formatted %></p>
              </div>
            </div>

            <%# Price + Change (always visible) — updated in real-time by binance-ticker controller %>
            <div class="text-right shrink-0">
              <p class="font-medium text-primary text-lg"
                 data-binance-ticker-target="price"
                 data-symbol="<%= quote.symbol %>">$<%= quote.price_formatted %></p>
              <p class="text-sm font-medium <%= quote.change_positive? ? trend_up_color_class : trend_down_color_class %>"
                 data-binance-ticker-target="change"
                 data-symbol="<%= quote.symbol %>"><%= quote.change_formatted %></p>
            </div>

            <%# Chart button %>
            <div class="shrink-0">
              <button type="button"
                      class="p-1.5 rounded-md hover:bg-surface-hover text-secondary hover:text-primary"
                      data-action="click->market-chart#toggle">
                <%= icon "chart-candlestick", size: "sm" %>
              </button>
            </div>
          </div>

          <div data-market-chart-target="chart" hidden class="px-4 pb-4"></div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-container rounded-xl shadow-border-xs p-4">
      <div class="flex justify-center items-center py-20">
        <div class="text-center space-y-2">
          <p class="text-sm text-primary font-medium"><%= t(".empty") %></p>
          <p class="text-sm text-secondary"><%= t(".empty_hint") %></p>
          <%= render DS::Link.new(text: t(".manage"), href: settings_watchlist_path, variant: "primary") %>
        </div>
      </div>
    </div>
  <% end %>
</div>
