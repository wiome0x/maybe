<footer class="p-6">
  <div class="space-y-2 text-center text-xs text-secondary">
    <% if app_website_url.present? %>
      <p>
        &copy; <%= Date.current.year %>,
        <%= link_to app_display_name, app_website_url, class: "text-secondary hover:underline", target: "_blank", rel: "noopener noreferrer" %>
      </p>
    <% else %>
      <p>&copy; <%= Date.current.year %>, <%= app_display_name %></p>
    <% end %>
    <div class="flex justify-center items-center gap-2">
      <%= link_to t("layouts.shared.footer.privacy_policy"), app_privacy_policy_url, class: "text-secondary", target: "_blank", rel: "noopener noreferrer" %>
      <span>&bull;</span>
      <%= link_to t("layouts.shared.footer.terms_of_service"), app_terms_of_service_url, class: "text-secondary", target: "_blank", rel: "noopener noreferrer" %>
    </div>
  </div>
</footer>
