<div class="space-y-4 pb-20">
  <header class="flex justify-between items-center">
    <h1 class="text-xl font-medium text-primary"><%= t(".title") %></h1>
    <div class="flex items-center gap-2 text-xs text-secondary">
      <%= icon "rss", size: "sm" %>
      <span><%= t(".source") %></span>
    </div>
  </header>

  <div class="bg-container rounded-xl shadow-border-xs p-4">
    <% if @articles.any? %>
      <div class="bg-container-inset rounded-xl p-1">
        <div class="bg-container rounded-lg shadow-border-xs">
          <% @articles.each_with_index do |article, idx| %>
            <div class="px-4 py-3 flex items-start justify-between gap-4">
              <div class="flex items-start gap-3 flex-1 min-w-0">
                <div class="shrink-0 mt-1">
                  <%= icon "file-text", size: "sm", class: "text-secondary" %>
                </div>
                <a href="<%= article[:url] %>"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="text-sm text-primary hover:underline leading-relaxed">
                  <%= sanitize article[:title], tags: [] %>
                </a>
              </div>
              <% if article[:time].present? %>
                <span class="text-xs text-secondary whitespace-nowrap shrink-0 mt-0.5"><%= sanitize article[:time], tags: [] %></span>
              <% end %>
            </div>
            <% if idx < @articles.size - 1 %>
              <%= render "shared/ruler" %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="flex justify-center items-center py-20">
        <div class="text-center space-y-2">
          <p class="text-sm text-primary font-medium"><%= t(".empty") %></p>
          <p class="text-sm text-secondary"><%= t(".empty_hint") %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>
