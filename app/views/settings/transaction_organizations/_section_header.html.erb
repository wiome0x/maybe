<%# locals: (eyebrow:, title:, description:) %>

<div class="space-y-2">
  <div>
    <p class="text-xs uppercase tracking-wide text-secondary"><%= eyebrow %></p>
    <h2 class="text-primary text-lg font-medium mt-1"><%= title %></h2>
  </div>

  <% if description.present? %>
    <p class="text-sm text-secondary"><%= description %></p>
  <% end %>
</div>
