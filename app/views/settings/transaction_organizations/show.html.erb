<% content_for :page_title, t(".page_title") %>

<section class="bg-container rounded-xl shadow-border-xs p-5">
  <div class="space-y-3">
    <%= render "section_header",
               eyebrow: t(".eyebrow"),
               title: t(".title"),
               description: t(".description") %>

    <div class="grid gap-3 md:grid-cols-3">
      <div class="rounded-lg bg-container-inset p-4">
        <p class="text-xs uppercase text-secondary mb-1"><%= t(".category_label") %></p>
        <p class="text-sm text-primary"><%= t(".category_body") %></p>
      </div>
      <div class="rounded-lg bg-container-inset p-4">
        <p class="text-xs uppercase text-secondary mb-1"><%= t(".merchant_label") %></p>
        <p class="text-sm text-primary"><%= t(".merchant_body") %></p>
      </div>
      <div class="rounded-lg bg-container-inset p-4">
        <p class="text-xs uppercase text-secondary mb-1"><%= t(".tag_label") %></p>
        <p class="text-sm text-primary"><%= t(".tag_body") %></p>
      </div>
    </div>

    <div class="rounded-lg border border-secondary p-4">
      <p class="text-xs uppercase text-secondary mb-1"><%= t(".status_label") %></p>
      <p class="text-sm text-primary"><%= t(".status_body") %></p>
    </div>
  </div>
</section>

<section class="bg-container rounded-xl shadow-border-xs p-5">
  <div class="space-y-4">
    <%= render "section_header",
               eyebrow: t(".entrypoints_label"),
               title: t(".entrypoints_title"),
               description: t(".entrypoints_description") %>

    <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
      <%= render "entrypoint_card",
                 label: t(".rules_label"),
                 body: t(".rules_card_body"),
                 count_text: t(".rules_count", count: @rules_count),
                 cta_text: t(".rules_cta"),
                 href: rules_path,
                 icon: "git-branch" %>

      <%= render "entrypoint_card",
                 label: t(".category_label"),
                 body: t(".category_card_body"),
                 count_text: t(".categories_count", count: @categories_count),
                 cta_text: t(".categories_cta"),
                 href: categories_path,
                 icon: "shapes" %>

      <%= render "entrypoint_card",
                 label: t(".merchant_label"),
                 body: t(".merchant_card_body"),
                 count_text: t(".merchants_count", count: @merchants_count),
                 cta_text: t(".merchants_cta"),
                 href: family_merchants_path,
                 icon: "store" %>

      <%= render "entrypoint_card",
                 label: t(".tag_label"),
                 body: t(".tag_card_body"),
                 count_text: t(".tags_count", count: @tags_count),
                 cta_text: t(".tags_cta"),
                 href: tags_path,
                 icon: "tags" %>
    </div>
  </div>
</section>

<section class="bg-container rounded-xl shadow-border-xs p-5">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div class="space-y-2">
      <%= render "section_header",
                 eyebrow: t(".rules_label"),
                 title: t(".rules_title"),
                 description: t(".rules_description") %>
      <p class="text-sm text-primary"><%= t(".rules_count", count: @rules_count) %></p>
    </div>

    <div class="flex items-center gap-2">
      <%= render DS::Link.new(
        text: t(".rules_cta"),
        variant: "primary",
        href: rules_path,
        icon: "git-branch"
      ) %>
    </div>
  </div>
</section>

<section class="bg-container rounded-xl shadow-border-xs p-5">
  <div class="space-y-3">
    <%= render "section_header",
               eyebrow: t(".example_label"),
               title: t(".example_title"),
               description: "" %>

    <div class="rounded-lg bg-container-inset p-4 space-y-2">
      <p class="text-sm text-primary"><%= t(".example_case") %></p>
      <p class="text-sm text-secondary"><%= t(".example_result") %></p>
    </div>
  </div>
</section>
