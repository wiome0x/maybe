<%= content_for :page_title, "Scheduled Jobs" %>

<div class="mb-4 flex items-center gap-2">
  <% [["7", "7 days"], ["30", "30 days"], ["90", "90 days"]].each do |value, label| %>
    <%= link_to label, settings_scheduled_job_runs_path(days: value),
      class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors #{@days.to_s == value ? 'bg-container-inset text-primary' : 'text-secondary hover:text-primary'}" %>
  <% end %>
</div>

<%= settings_section title: "Latest run per job" do %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    <% @latest_runs.each do |job_name, run| %>
      <div class="bg-container-inset rounded-lg p-4 space-y-1">
        <div class="flex items-center justify-between gap-2">
          <p class="text-xs font-mono text-secondary truncate"><%= job_name %></p>
          <% if run %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= run.status == 'completed' ? 'text-success' : run.status == 'failed' ? 'text-destructive' : 'text-warning' %>">
              <%= run.status %>
            </span>
          <% else %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium text-secondary">never run</span>
          <% end %>
        </div>
        <% if run %>
          <p class="text-sm font-medium text-primary"><%= run.run_date %></p>
          <p class="text-xs text-secondary">
            <% if run.duration_seconds %>
              <%= run.duration_seconds %>s
            <% end %>
            <% if run.records_written %>
              &middot; <%= number_with_delimiter(run.records_written) %> records
            <% end %>
          </p>
          <% if run.error_message.present? %>
            <p class="text-xs text-destructive truncate" title="<%= run.error_message %>"><%= run.error_message %></p>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%= settings_section title: "Run history (last <%= @days %> days)" do %>
  <% if @recent_runs.any? %>
    <div class="bg-container-inset rounded-xl p-1">
      <div class="px-4 py-2 grid grid-cols-12 text-xs font-medium text-secondary uppercase hidden md:grid">
        <div class="col-span-4">Job</div>
        <div class="col-span-2">Date</div>
        <div class="col-span-2">Status</div>
        <div class="col-span-1 text-right">Duration</div>
        <div class="col-span-2 text-right">Records</div>
        <div class="col-span-1 text-right">Source</div>
      </div>
      <div class="bg-container rounded-lg shadow-border-xs divide-y divide-primary">
        <% @recent_runs.each do |run| %>
          <div class="px-4 py-3 grid grid-cols-12 items-center text-sm">
            <div class="col-span-4 font-mono text-xs text-secondary truncate"><%= run.job_name %></div>
            <div class="col-span-2 text-primary"><%= run.run_date %></div>
            <div class="col-span-2">
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                <%= run.status == 'completed' ? 'text-success' : run.status == 'failed' ? 'text-destructive' : 'text-warning' %>">
                <%= run.status %>
              </span>
            </div>
            <div class="col-span-1 text-right text-secondary text-xs">
              <%= run.duration_seconds ? "#{run.duration_seconds}s" : "—" %>
            </div>
            <div class="col-span-2 text-right text-secondary text-xs">
              <%= run.records_written ? number_with_delimiter(run.records_written) : "—" %>
            </div>
            <div class="col-span-1 text-right text-secondary text-xs truncate">
              <%= run.source.presence || "—" %>
            </div>
          </div>
          <% if run.error_message.present? %>
            <div class="px-4 pb-2 text-xs text-destructive col-span-12">
              <%= run.error_message %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% else %>
    <p class="text-secondary text-sm text-center py-8">No runs recorded in the last <%= @days %> days.</p>
  <% end %>
<% end %>
