<%= content_for :page_title, t(".page_title") %>

<% if @newly_created && @plain_key %>
  <%= settings_section title: t(".newly_created.section_title"), subtitle: t(".newly_created.section_subtitle") do %>
    <div class="space-y-4">
      <div class="p-3 shadow-border-xs bg-container rounded-lg">
        <div class="flex items-start gap-3">
          <%= render DS::FilledIcon.new(
            icon: "check-circle",
            rounded: true,
            size: "lg",
            variant: :success
          ) %>
          <div class="flex-1">
            <h3 class="font-medium text-primary"><%= t(".newly_created.success_title") %></h3>
            <p class="text-secondary text-sm mt-1"><%= t(".newly_created.success_body", key_name: @current_api_key.name) %></p>
          </div>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3"><%= t(".shared.your_api_key") %></h4>
        <p class="text-secondary text-sm mb-3"><%= t(".shared.copy_hint") %></p>

        <div class="bg-container rounded-lg p-3 border border-primary" data-controller="clipboard">
          <div class="flex items-center justify-between gap-3">
            <code id="api-key-display" class="font-mono text-sm text-primary break-all" data-clipboard-target="source"><%= @current_api_key.plain_key %></code>
            <%= render DS::Button.new(
              text: t(".shared.copy_api_key"),
              variant: "ghost",
              icon: "copy",
              data: { action: "clipboard#copy" }
            ) %>
          </div>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3"><%= t(".shared.usage_title") %></h4>
        <p class="text-secondary text-sm mb-3"><%= t(".shared.usage_hint") %></p>
        <div class="bg-container rounded-lg p-3 font-mono text-sm text-primary border border-primary">
          curl -H "X-Api-Key: <%= @current_api_key.plain_key %>" <%= request.base_url %>/api/v1/accounts
        </div>
      </div>

      <div class="flex justify-end pt-4 border-t border-primary">
        <%= render DS::Link.new(
          text: t(".newly_created.continue"),
          href: settings_api_key_path,
          variant: "primary"
        ) %>
      </div>
    </div>
  <% end %>
<% elsif @current_api_key %>
  <%= settings_section title: t(".current.section_title"), subtitle: t(".current.section_subtitle") do %>
    <div class="space-y-4">
      <div class="p-3 shadow-border-xs bg-container rounded-lg flex justify-between items-center">
        <div class="flex items-center gap-3">
          <%= render DS::FilledIcon.new(
            icon: "key",
            rounded: true,
            size: "lg"
          ) %>

          <div class="text-sm space-y-1">
            <p class="text-primary font-medium"><%= @current_api_key.name %></p>
            <p class="text-secondary">
              <%= t(".current.created_ago", time_ago: time_ago_in_words(@current_api_key.created_at)) %>
              <% if @current_api_key.last_used_at %>
                <%= t(".current.last_used_ago", time_ago: time_ago_in_words(@current_api_key.last_used_at)) %>
              <% else %>
                <%= t(".current.never_used") %>
              <% end %>
            </p>
          </div>
        </div>

        <div class="rounded-md bg-success px-2 py-1">
          <p class="text-success-foreground font-medium text-xs"><%= t(".current.active") %></p>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3"><%= t(".current.permissions") %></h4>
        <div class="flex flex-wrap gap-2">
          <% @current_api_key.scopes.each do |scope| %>
            <span class="inline-flex items-center gap-1 px-2 py-1 bg-primary text-primary-foreground rounded-full text-xs font-medium">
              <%= icon("shield-check", class: "w-3 h-3") %>
              <%= t("settings.api_keys.shared.scopes.#{scope}", default: scope.humanize) %>
            </span>
          <% end %>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3"><%= t(".shared.your_api_key") %></h4>
        <p class="text-secondary text-sm mb-3"><%= t(".shared.copy_hint") %></p>

        <div class="bg-container rounded-lg p-3 border border-primary" data-controller="clipboard">
          <div class="flex items-center justify-between gap-3">
            <code id="api-key-display" class="font-mono text-sm text-primary break-all" data-clipboard-target="source"><%= @current_api_key.plain_key %></code>
            <%= render DS::Button.new(
              text: t(".shared.copy_api_key"),
              variant: "ghost",
              icon: "copy",
              data: { action: "clipboard#copy" }
            ) %>
          </div>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3"><%= t(".shared.usage_title") %></h4>
        <p class="text-secondary text-sm mb-3"><%= t(".shared.usage_hint") %></p>
        <div class="bg-container rounded-lg p-3 font-mono text-sm text-primary border border-primary">
          curl -H "X-Api-Key: <%= @current_api_key.plain_key %>" <%= request.base_url %>/api/v1/accounts
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-primary">
        <%= render DS::Link.new(
          text: t(".current.create_new_key"),
          href: new_settings_api_key_path(regenerate: true),
          variant: "secondary"
        ) %>

        <%= render DS::Button.new(
          text: t(".current.revoke_key"),
          href: settings_api_key_path,
          method: :delete,
          variant: "destructive",
          data: {
            turbo_confirm: t(".current.revoke_confirm")
          }
        ) %>
      </div>
    </div>
  <% end %>
<% else %>
  <%= settings_section title: t(".empty.section_title"), subtitle: t(".empty.section_subtitle") do %>
    <div class="space-y-4">
      <div class="p-3 shadow-border-xs bg-container rounded-lg">
        <div class="flex items-start gap-3">
          <%= render DS::FilledIcon.new(
            icon: "key",
            rounded: true,
            size: "lg"
          ) %>
          <div class="flex-1">
            <h3 class="font-medium text-primary"><%= t(".empty.card_title") %></h3>
            <p class="text-secondary text-sm mt-1"><%= t(".empty.card_body") %></p>
          </div>
        </div>
      </div>

      <div class="bg-surface-inset rounded-xl p-4">
        <h4 class="font-medium text-primary mb-3"><%= t(".empty.features_title") %></h4>
        <ul class="space-y-2 text-sm text-secondary">
          <li class="flex items-start gap-2">
            <%= icon("check", class: "w-4 h-4 text-primary mt-0.5") %>
            <span><%= t(".empty.feature_1") %></span>
          </li>
          <li class="flex items-start gap-2">
            <%= icon("check", class: "w-4 h-4 text-primary mt-0.5") %>
            <span><%= t(".empty.feature_2") %></span>
          </li>
          <li class="flex items-start gap-2">
            <%= icon("check", class: "w-4 h-4 text-primary mt-0.5") %>
            <span><%= t(".empty.feature_3") %></span>
          </li>
          <li class="flex items-start gap-2">
            <%= icon("check", class: "w-4 h-4 text-primary mt-0.5") %>
            <span><%= t(".empty.feature_4") %></span>
          </li>
        </ul>
      </div>

      <div class="flex justify-start">
        <%= render DS::Link.new(
          text: t(".empty.create_api_key"),
          href: new_settings_api_key_path,
          variant: "primary"
        ) %>
      </div>
    </div>
  <% end %>
<% end %>
