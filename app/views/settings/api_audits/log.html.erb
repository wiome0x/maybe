<%= render DS::Dialog.new(variant: "drawer") do |dialog| %>
  <% dialog.with_header do %>
    <div class="space-y-1">
      <p class="text-sm text-secondary">
        <%= @audit_mode == "plaid" ? "plaid/#{@log.region}" : @log.provider_name %>
      </p>
      <h3 class="text-2xl font-medium text-primary"><%= @log.endpoint %></h3>
      <p class="text-sm text-secondary">
        <%= @log.requested_at.in_time_zone(@display_timezone).strftime("%Y-%m-%d %H:%M:%S %Z") %>
      </p>
    </div>
  <% end %>

  <% dialog.with_body do %>
    <% status = @audit_mode == "plaid" ? (@log.success ? "success" : "error") : @log.request_status %>
    <% response_code = @audit_mode == "plaid" ? @log.http_status : @log.response_code %>
    <% response_time = @audit_mode == "plaid" ? @log.duration_ms : @log.response_time_ms %>
    <% request_payload = @log.request_payload %>
    <% response_payload = @log.response_payload %>
    <% error_payload = @log.error_payload %>

    <% dialog.with_section(title: t("settings.api_audits.show.detail_overview"), open: true) do %>
      <div class="pb-4">
        <dl class="space-y-3 px-3 py-2">
          <div class="flex items-center justify-between text-sm">
            <dt class="text-secondary"><%= t("settings.api_audits.show.col_provider") %></dt>
            <dd class="text-primary"><%= @audit_mode == "plaid" ? "plaid/#{@log.region}" : @log.provider_name %></dd>
          </div>
          <div class="flex items-center justify-between text-sm">
            <dt class="text-secondary"><%= t("settings.api_audits.show.col_method") %></dt>
            <dd class="text-primary"><%= @audit_mode == "plaid" ? @log.source : @log.http_method %></dd>
          </div>
          <div class="flex items-center justify-between text-sm">
            <dt class="text-secondary"><%= t("settings.api_audits.show.col_status") %></dt>
            <dd class="<%= status == 'error' ? 'text-destructive' : 'text-success' %>"><%= status %></dd>
          </div>
          <div class="flex items-center justify-between text-sm">
            <dt class="text-secondary"><%= t("settings.api_audits.show.col_code") %></dt>
            <dd class="text-primary"><%= response_code.presence || "-" %></dd>
          </div>
          <div class="flex items-center justify-between text-sm">
            <dt class="text-secondary"><%= t("settings.api_audits.show.col_response_time") %></dt>
            <dd class="text-primary"><%= response_time&.round(1) || "-" %> ms</dd>
          </div>
          <% if @audit_mode == "plaid" && @log.plaid_request_id.present? %>
            <div class="flex items-center justify-between text-sm">
              <dt class="text-secondary"><%= t("settings.api_audits.show.plaid_request_id") %></dt>
              <dd class="text-primary font-mono"><%= @log.plaid_request_id %></dd>
            </div>
          <% end %>
          <% if @audit_mode == "plaid" && (@log.webhook_type.present? || @log.webhook_code.present?) %>
            <div class="flex items-center justify-between text-sm">
              <dt class="text-secondary"><%= t("settings.api_audits.show.webhook_event") %></dt>
              <dd class="text-primary"><%= [@log.webhook_type, @log.webhook_code].compact.join(" / ") %></dd>
            </div>
          <% end %>
          <% if @audit_mode == "api" && @log.error_message.present? %>
            <div class="flex items-start justify-between gap-4 text-sm">
              <dt class="text-secondary shrink-0"><%= t("settings.api_audits.show.error_message") %></dt>
              <dd class="text-destructive text-right"><%= @log.error_message %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>

    <% dialog.with_section(title: t("settings.api_audits.show.request_section"), open: true) do %>
      <div class="pb-4 px-3">
        <% if request_payload.present? %>
          <pre class="text-primary text-xs font-mono whitespace-pre-wrap break-all bg-container-inset rounded-lg p-3"><%= formatted_audit_payload(request_payload) %></pre>
        <% else %>
          <p class="text-sm text-secondary"><%= t("settings.api_audits.show.no_request_payload") %></p>
        <% end %>
      </div>
    <% end %>

    <% dialog.with_section(title: t("settings.api_audits.show.response_section")) do %>
      <div class="pb-4 px-3">
        <% if response_payload.present? %>
          <pre class="text-primary text-xs font-mono whitespace-pre-wrap break-all bg-container-inset rounded-lg p-3"><%= formatted_audit_payload(response_payload) %></pre>
        <% else %>
          <p class="text-sm text-secondary"><%= t("settings.api_audits.show.no_response_payload") %></p>
        <% end %>
      </div>
    <% end %>

    <% dialog.with_section(title: t("settings.api_audits.show.error_section")) do %>
      <div class="pb-4 px-3">
        <% if error_payload.present? %>
          <pre class="text-primary text-xs font-mono whitespace-pre-wrap break-all bg-container-inset rounded-lg p-3"><%= formatted_audit_payload(error_payload) %></pre>
        <% else %>
          <p class="text-sm text-secondary"><%= t("settings.api_audits.show.no_error_payload") %></p>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
