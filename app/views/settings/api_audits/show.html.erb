<%= content_for :page_title, t(".page_title") %>

<div class="mb-4">
  <nav class="flex items-center gap-2" aria-label="Audit mode filter">
    <%= link_to "API",
      settings_api_audit_path(audit_mode: "api", period: params[:period]),
      class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors #{@audit_mode == 'api' ? 'bg-container-inset text-primary' : 'text-secondary hover:text-primary'}" %>
    <%= link_to "Plaid",
      settings_api_audit_path(audit_mode: "plaid", period: params[:period]),
      class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors #{@audit_mode == 'plaid' ? 'bg-container-inset text-primary' : 'text-secondary hover:text-primary'}" %>
  </nav>
</div>

<%# Task 7.1: Time range filter + Summary metric cards %>
<%= settings_section title: t(".overview_title"), subtitle: t(".overview_subtitle") do %>
  <div class="space-y-4">
    <nav class="flex items-center gap-2" aria-label="Time range filter">
      <% [["7d", t(".period_7d")], ["30d", t(".period_30d")], ["90d", t(".period_90d")]].each do |period_key, label| %>
        <% active = (@period_days == 7 && period_key == "7d") || (@period_days == 30 && period_key == "30d") || (@period_days == 90 && period_key == "90d") %>
        <%= link_to label, settings_api_audit_path(period: period_key, audit_mode: @audit_mode),
          class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors #{active ? 'bg-container-inset text-primary' : 'text-secondary hover:text-primary'}" %>
      <% end %>
    </nav>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-container-inset rounded-lg p-4">
        <p class="text-xs text-secondary uppercase font-medium"><%= t(".total_requests") %></p>
        <p class="text-xl font-semibold text-primary mt-1"><%= number_with_delimiter(@stats[:total_requests]) %></p>
      </div>
      <div class="bg-container-inset rounded-lg p-4">
        <p class="text-xs text-secondary uppercase font-medium"><%= t(".total_errors") %></p>
        <p class="text-xl font-semibold text-destructive mt-1"><%= number_with_delimiter(@stats[:total_errors]) %></p>
      </div>
      <div class="bg-container-inset rounded-lg p-4">
        <p class="text-xs text-secondary uppercase font-medium"><%= t(".error_rate") %></p>
        <p class="text-xl font-semibold text-primary mt-1"><%= @stats[:error_rate] %>%</p>
      </div>
      <div class="bg-container-inset rounded-lg p-4">
        <p class="text-xs text-secondary uppercase font-medium"><%= t(".avg_response_time") %></p>
        <p class="text-xl font-semibold text-primary mt-1"><%= @stats[:avg_response_time_ms] %> ms</p>
      </div>
    </div>
  </div>
<% end %>

<%# Task 7.2: Trend line chart area %>
<%= settings_section title: t(".trends_title"), subtitle: t(".trends_subtitle") do %>
  <div data-controller="audit-line-chart"
       data-audit-line-chart-data-value="<%= @daily_totals.map { |d| { date: d.date.to_s, total: d.total, success_count: d.success_count, error_count: d.error_count } }.to_json %>"
       class="w-full h-64">
  </div>
<% end %>

<%# Task 7.3: Provider bar chart area %>
<%= settings_section title: t(".provider_title"), subtitle: t(".provider_subtitle") do %>
  <div data-controller="audit-bar-chart"
       data-audit-bar-chart-data-value="<%= @provider_summary.map { |p| { provider_name: p.provider_name, total: p.total, error_count: p.error_count } }.to_json %>"
       class="w-full h-64">
  </div>
<% end %>

<%# Task 7.4: Log list area %>
<%= settings_section title: t(".logs_title"), subtitle: t(".logs_subtitle") do %>
  <div class="space-y-4">
    <nav class="flex items-center gap-2 flex-wrap" aria-label="Provider filter">
      <%= link_to t(".filter_all"), settings_api_audit_path(period: params[:period], audit_mode: @audit_mode),
        class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors #{params[:provider].blank? ? 'bg-container-inset text-primary' : 'text-secondary hover:text-primary'}" %>
      <% @provider_summary.each do |provider| %>
        <%= link_to provider.provider_name, settings_api_audit_path(provider: provider.provider_name, period: params[:period], audit_mode: @audit_mode),
          class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors #{params[:provider] == provider.provider_name ? 'bg-container-inset text-primary' : 'text-secondary hover:text-primary'}" %>
      <% end %>
    </nav>

    <% if @logs.any? %>
      <div class="bg-container-inset rounded-xl p-1">
        <div class="px-4 py-2 grid grid-cols-12 text-xs font-medium text-secondary uppercase hidden md:grid">
          <div class="col-span-2"><%= t(".col_provider") %></div>
          <div class="col-span-3"><%= t(".col_endpoint") %></div>
          <div class="col-span-1"><%= t(".col_method") %></div>
          <div class="col-span-1"><%= t(".col_status") %></div>
          <div class="col-span-1 text-right"><%= t(".col_code") %></div>
          <div class="col-span-2 text-right"><%= t(".col_response_time") %></div>
          <div class="col-span-2 text-right"><%= t(".col_requested_at") %></div>
        </div>

        <div class="bg-container rounded-lg shadow-border-xs">
          <% @logs.each_with_index do |log, idx| %>
            <% status = @audit_mode == "plaid" ? (log.success ? "success" : "error") : log.request_status %>
            <div class="px-4 py-3 grid grid-cols-12 items-center text-sm <%= status == 'error' ? 'text-destructive' : 'text-primary' %>">
              <div class="col-span-2 font-medium truncate">
                <% if @audit_mode == "plaid" %>
                  <%= "plaid/#{log.region}" %>
                <% else %>
                  <%= log.provider_name %>
                <% end %>
              </div>
              <div class="col-span-3 font-mono text-xs">
                <div class="truncate"><%= log.endpoint %></div>
                <% if @audit_mode == "plaid" %>
                  <div class="text-[11px] text-secondary truncate">
                    <% details = [] %>
                    <% details << "request_id=#{log.plaid_request_id}" if log.plaid_request_id.present? %>
                    <% details << "webhook=#{log.webhook_type}/#{log.webhook_code}" if log.webhook_type.present? || log.webhook_code.present? %>
                    <% details << "error=#{log.error_payload['message']}" if log.error_payload.is_a?(Hash) && log.error_payload["message"].present? %>
                    <%= details.join(" | ") %>
                  </div>
                <% end %>
              </div>
              <div class="col-span-1"><%= @audit_mode == "plaid" ? log.source : log.http_method %></div>
              <div class="col-span-1">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= status == 'success' ? 'text-success' : 'text-destructive' %>">
                  <%= status %>
                </span>
              </div>
              <div class="col-span-1 text-right"><%= @audit_mode == "plaid" ? log.http_status : log.response_code %></div>
              <div class="col-span-2 text-right"><%= @audit_mode == "plaid" ? log.duration_ms&.round(1) : log.response_time_ms&.round(1) %> ms</div>
              <div class="col-span-2 text-right text-secondary"><%= log.requested_at.strftime("%Y-%m-%d %H:%M") %></div>
            </div>
            <% if idx < @logs.size - 1 %>
              <%= render "shared/ruler" %>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="flex justify-center mt-4">
        <%= raw pagy_nav(@pagy) %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-secondary text-sm"><%= t(".no_logs") %></p>
      </div>
    <% end %>
  </div>
<% end %>
