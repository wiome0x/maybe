<%= content_for :page_title, "Watchlist" %>

<%= settings_section title: "Stocks Watchlist", subtitle: "Drag to reorder. US stocks to track on the Markets page." do %>
  <div class="space-y-4">
    <%= form_with url: settings_watchlist_items_path, method: :post, class: "flex gap-2" do |f| %>
      <%= tag.input name: "watchlist_item[symbol]", placeholder: "e.g. AAPL, TSLA",
            class: "form-field__input grow uppercase",
            required: true,
            autocomplete: "off" %>
      <%= tag.input name: "watchlist_item[item_type]", type: "hidden", value: "stock" %>
      <%= render DS::Button.new(text: "Add", variant: "primary", type: "submit") %>
    <% end %>

    <% if @stock_items.any? %>
      <div class="bg-container-inset rounded-xl p-1"
           data-controller="sortable-list"
           data-sortable-list-url-value="<%= reorder_settings_watchlist_path %>">
        <div class="bg-container rounded-lg shadow-border-xs">
          <% @stock_items.each_with_index do |item, idx| %>
            <div class="flex items-center justify-between px-4 py-3"
                 data-sortable-list-target="item"
                 data-item-id="<%= item.id %>">
              <div class="flex items-center gap-3">
                <span class="cursor-grab text-secondary hover:text-primary">
                  <%= icon "grip-vertical", size: "sm" %>
                </span>
                <%= render DS::FilledIcon.new(variant: :text, text: item.symbol, size: "sm", rounded: true) %>
                <div>
                  <p class="text-sm font-medium text-primary"><%= item.symbol %></p>
                  <p class="text-xs text-secondary"><%= item.name %></p>
                </div>
              </div>
              <%= button_to settings_watchlist_item_path(item), method: :delete,
                    class: "text-secondary hover:text-destructive" do %>
                <%= icon "x", size: "sm" %>
              <% end %>
            </div>
            <% if idx < @stock_items.size - 1 %>
              <%= render "shared/ruler" %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-secondary">No stocks added yet.</p>
    <% end %>
  </div>
<% end %>

<%= settings_section title: "Crypto Watchlist", subtitle: "Drag to reorder. Cryptocurrencies to track on the Markets page." do %>
