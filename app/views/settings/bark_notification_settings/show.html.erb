<%= content_for :page_title, t(".page_title") %>

<%= settings_section title: t(".subscription_title"), subtitle: t(".subscription_subtitle") do %>
  <%= styled_form_with model: @subscription, url: settings_bark_notification_path, method: :patch, class: "space-y-4" do |form| %>
    <div class="rounded-xl bg-container-inset p-4">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-primary"><%= t(".enabled_label") %></p>
          <p class="text-sm text-secondary"><%= t(".enabled_hint") %></p>
        </div>
        <%= form.toggle :enabled %>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <%= form.text_field :server_url, label: t(".server_url"), placeholder: BarkNotifier::DEFAULT_SERVER_URL %>
      <%= form.text_field :device_key, label: t(".device_key"), placeholder: "your-device-key", required: true %>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <%= form.select :delivery_frequency, @frequency_options, { label: t(".delivery_frequency") } %>
      <%= form.select :digest_hour, @hour_options, { label: t(".digest_hour") } %>
    </div>

    <%= form.select :timezone, timezone_options, { label: t(".timezone") } %>

    <div class="grid gap-4 md:grid-cols-3">
      <%= form.text_field :group_name, label: t(".group_name"), placeholder: "Maybe Finance" %>
      <%= form.text_field :sound, label: t(".sound"), placeholder: "minuet" %>
      <%= form.text_field :icon, label: t(".icon"), placeholder: "https://example.com/icon.png" %>
    </div>

    <div class="rounded-xl bg-container-inset p-4 space-y-3">
      <div>
        <p class="text-sm font-medium text-primary"><%= t(".categories_title") %></p>
        <p class="text-sm text-secondary"><%= t(".categories_hint") %></p>
      </div>

      <%= hidden_field_tag "bark_notification_subscription[push_categories][]", "" %>

      <div class="space-y-3">
        <% @category_options.each do |label, value| %>
          <label class="flex items-center gap-2.5 p-4 rounded-lg border border-tertiary cursor-pointer hover:bg-container transition-colors [&:has(input:checked)]:border-solid [&:has(input:checked)]:bg-container">
            <%= form.check_box :push_categories, { multiple: true, class: "sr-only", checked: @subscription.push_categories.include?(value) }, value, nil %>
            <%= icon "bell-ring", class: "shrink-0" %>
            <span class="text-primary text-sm"><%= label %></span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="flex justify-end">
      <%= render DS::Button.new(text: t(".save"), class: "md:w-auto w-full justify-center") %>
    </div>
  <% end %>
<% end %>

<% if @subscription.persisted? %>
  <%= settings_section title: t(".test_title"), subtitle: t(".test_subtitle") do %>
    <div class="rounded-xl bg-container-inset p-4 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <div class="space-y-1">
        <p class="text-sm font-medium text-primary"><%= t(".send_test") %></p>
        <p class="text-sm text-secondary"><%= t(".send_test_hint") %></p>
      </div>

      <%= button_to t(".send_test"),
          test_settings_bark_notification_path,
          method: :post,
          class: "inline-flex items-center justify-center rounded-xl border border-primary px-4 py-2 text-sm font-medium text-primary hover:bg-container md:w-auto w-full" %>
    </div>
  <% end %>

  <%= settings_section title: "大盘异动预警", subtitle: "当美股指数或个股涨跌幅触发阈值时，立即推送 Bark 通知。" do %>
    <%# Preset quick-add buttons %>
    <div class="space-y-4">
      <div>
        <p class="text-xs font-medium text-secondary uppercase mb-2">快速添加预设</p>
        <div class="flex flex-wrap gap-2">
          <% MarketAlertRule::PRESETS.each do |preset| %>
            <% already_exists = @alert_rules.any? { |r| r.symbol == preset[:symbol] && r.condition == preset[:condition] } %>
            <% unless already_exists %>
              <%= styled_form_with url: settings_market_alert_rules_path, method: :post do |f| %>
                <%= hidden_field_tag "market_alert_rule[symbol]", preset[:symbol] %>
                <%= hidden_field_tag "market_alert_rule[name]", preset[:name] %>
                <%= hidden_field_tag "market_alert_rule[condition]", preset[:condition] %>
                <%= hidden_field_tag "market_alert_rule[threshold]", preset[:threshold] %>
                <button type="submit" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-primary text-sm text-secondary hover:bg-container-inset transition-colors">
                  <%= icon("plus", size: "sm") %>
                  <%= preset[:name] %> 跌 <%= preset[:threshold].abs %>%
                </button>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Existing rules %>
      <% if @alert_rules.any? %>
        <div class="bg-container-inset rounded-xl p-1">
          <% @alert_rules.each_with_index do |rule, idx| %>
            <div class="flex items-center justify-between px-4 py-3 text-sm">
              <div class="flex items-center gap-3">
                <span class="font-mono text-xs bg-container px-2 py-0.5 rounded text-secondary"><%= rule.symbol %></span>
                <span class="text-primary"><%= rule.name.presence || rule.symbol %></span>
                <span class="text-secondary"><%= rule.condition_label %> <%= rule.threshold_display %></span>
              </div>
              <%= button_to settings_market_alert_rule_path(rule),
                            method: :delete,
                            data: { turbo_confirm: "Remove this alert rule?" },
                            class: "text-destructive hover:text-destructive/80 transition-colors" do %>
                <%= icon("x", size: "sm") %>
              <% end %>
            </div>
            <% if idx < @alert_rules.size - 1 %>
              <%= render "shared/ruler" %>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%# Custom rule form %>
      <details class="group">
        <summary class="cursor-pointer text-sm text-secondary hover:text-primary flex items-center gap-1.5 list-none">
          <%= icon("plus", size: "sm") %>
          自定义预警规则
        </summary>
        <div class="mt-3">
          <%= styled_form_with url: settings_market_alert_rules_path, method: :post, class: "space-y-3" do |f| %>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
              <div class="form-field">
                <div class="form-field__header"><label class="form-field__label">股票代码</label></div>
                <input type="text" name="market_alert_rule[symbol]" placeholder="^GSPC" class="form-field__input" required />
              </div>
              <div class="form-field">
                <div class="form-field__header"><label class="form-field__label">名称（可选）</label></div>
                <input type="text" name="market_alert_rule[name]" placeholder="S&P 500" class="form-field__input" />
              </div>
              <div class="form-field">
                <div class="form-field__header"><label class="form-field__label">条件</label></div>
                <select name="market_alert_rule[condition]" class="form-field__input">
                  <option value="change_percent_below">跌幅超过</option>
                  <option value="change_percent_above">涨幅超过</option>
                </select>
              </div>
              <div class="form-field">
                <div class="form-field__header"><label class="form-field__label">阈值 (%)</label></div>
                <input type="number" name="market_alert_rule[threshold]" placeholder="-5.0" step="0.1" class="form-field__input" required />
              </div>
            </div>
            <div>
              <button type="submit" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-surface text-white text-sm hover:bg-surface-hover transition-colors">
                <%= icon("plus", size: "sm") %>
                添加规则
              </button>
            </div>
          <% end %>
        </div>
      </details>
    </div>
  <% end %>
<% end %>
