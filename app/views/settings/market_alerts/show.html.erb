<%= content_for :page_title, t(".title") %>

<%# ── 第一级：大盘规则 ─────────────────────────────────────────── %>
<%= settings_section title: t(".market_title"), subtitle: t(".market_subtitle") do %>
  <div class="space-y-4">
    <%# Preset quick-add %>
    <div>
      <p class="text-xs font-medium text-secondary uppercase mb-2"><%= t(".presets") %></p>
      <div class="flex flex-wrap gap-2">
        <% @presets.each do |preset| %>
          <% exists = @market_rules.any? { |r| r.symbol == preset[:symbol] && r.condition == preset[:condition] } %>
          <% unless exists %>
            <%= form_with url: settings_market_alert_rules_path, method: :post do |f| %>
              <%= hidden_field_tag "market_alert_rule[symbol]",    preset[:symbol] %>
              <%= hidden_field_tag "market_alert_rule[name]",      preset[:name] %>
              <%= hidden_field_tag "market_alert_rule[condition]", preset[:condition] %>
              <%= hidden_field_tag "market_alert_rule[threshold]", preset[:threshold] %>
              <%= hidden_field_tag "market_alert_rule[rule_type]", "market" %>
              <button type="submit" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-primary text-sm text-secondary hover:bg-container-inset transition-colors">
                <%= icon("plus", size: "sm") %>
                <%= preset[:name] %> <%= preset[:threshold] %>%
              </button>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Existing market rules %>
    <% if @market_rules.any? %>
      <div class="bg-container-inset rounded-xl p-1">
        <div class="bg-container rounded-lg shadow-border-xs divide-y divide-primary">
          <% @market_rules.each do |rule| %>
            <div class="flex items-center justify-between px-4 py-3 text-sm">
              <div class="flex items-center gap-3">
                <span class="font-mono text-xs bg-container-inset px-2 py-0.5 rounded text-secondary"><%= rule.symbol %></span>
                <span class="text-primary"><%= rule.name.presence || rule.symbol %></span>
                <span class="text-secondary"><%= rule.condition_label %> <%= rule.threshold_display %></span>
              </div>
              <%= button_to settings_market_alert_rule_path(rule), method: :delete,
                    data: { turbo_confirm: t(".confirm_delete") },
                    class: "text-destructive hover:text-destructive/80 transition-colors" do %>
                <%= icon("x", size: "sm") %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Custom market rule form %>
    <details class="group">
      <summary class="cursor-pointer text-sm text-secondary hover:text-primary flex items-center gap-1.5 list-none">
        <%= icon("plus", size: "sm") %>
        <%= t(".custom_rule") %>
      </summary>
      <div class="mt-3">
        <%= form_with url: settings_market_alert_rules_path, method: :post, class: "space-y-3" do |f| %>
          <%= hidden_field_tag "market_alert_rule[rule_type]", "market" %>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="form-field">
              <div class="form-field__header"><label class="form-field__label"><%= t(".symbol") %></label></div>
              <input type="text" name="market_alert_rule[symbol]" placeholder="^GSPC" class="form-field__input" required />
            </div>
            <div class="form-field">
              <div class="form-field__header"><label class="form-field__label"><%= t(".name_optional") %></label></div>
              <input type="text" name="market_alert_rule[name]" placeholder="S&P 500" class="form-field__input" />
            </div>
            <div class="form-field">
              <div class="form-field__header"><label class="form-field__label"><%= t(".condition") %></label></div>
              <select name="market_alert_rule[condition]" class="form-field__input">
                <option value="change_percent_below"><%= t(".cond_change_below") %></option>
                <option value="change_percent_above"><%= t(".cond_change_above") %></option>
              </select>
            </div>
            <div class="form-field">
              <div class="form-field__header"><label class="form-field__label"><%= t(".threshold_pct") %></label></div>
              <input type="number" name="market_alert_rule[threshold]" placeholder="-2.0" step="0.1" class="form-field__input" required />
            </div>
          </div>
          <button type="submit" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-surface text-white text-sm hover:bg-surface-hover transition-colors">
            <%= icon("plus", size: "sm") %>
            <%= t(".add_rule") %>
          </button>
        <% end %>
      </div>
    </details>
  </div>
<% end %>

<%# ── 第二级：自选股规则 ───────────────────────────────────────── %>
<%= settings_section title: t(".watchlist_title"), subtitle: t(".watchlist_subtitle") do %>
  <div class="space-y-4">
    <% if @watchlist_rules.any? %>
      <div class="bg-container-inset rounded-xl p-1">
        <div class="bg-container rounded-lg shadow-border-xs divide-y divide-primary">
          <% @watchlist_rules.each do |rule| %>
            <div class="flex items-center justify-between px-4 py-3 text-sm">
              <div class="flex items-center gap-3">
                <span class="font-mono text-xs bg-container-inset px-2 py-0.5 rounded text-secondary"><%= rule.symbol %></span>
                <span class="text-primary"><%= rule.name.presence || rule.symbol %></span>
                <span class="text-secondary"><%= rule.condition_label %> <%= rule.threshold_display %></span>
              </div>
              <%= button_to settings_market_alert_rule_path(rule), method: :delete,
                    data: { turbo_confirm: t(".confirm_delete") },
                    class: "text-destructive hover:text-destructive/80 transition-colors" do %>
                <%= icon("x", size: "sm") %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%= form_with url: settings_market_alert_rules_path, method: :post, class: "space-y-3" do |f| %>
      <%= hidden_field_tag "market_alert_rule[rule_type]", "watchlist" %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="form-field">
          <div class="form-field__header"><label class="form-field__label"><%= t(".symbol") %></label></div>
          <select name="market_alert_rule[symbol]" class="form-field__input">
            <option value=""><%= t(".select_symbol") %></option>
            <% @watchlist_items.each do |item| %>
              <option value="<%= item.symbol %>"><%= item.symbol %><%= item.name.present? ? " — #{item.name}" : "" %></option>
            <% end %>
          </select>
        </div>
        <div class="form-field">
          <div class="form-field__header"><label class="form-field__label"><%= t(".condition") %></label></div>
          <select name="market_alert_rule[condition]" class="form-field__input">
            <option value="change_percent_below"><%= t(".cond_change_below") %></option>
            <option value="change_percent_above"><%= t(".cond_change_above") %></option>
            <option value="ma5_deviation_below"><%= t(".cond_ma5_below") %></option>
            <option value="ma5_deviation_above"><%= t(".cond_ma5_above") %></option>
            <option value="ma10_deviation_below"><%= t(".cond_ma10_below") %></option>
            <option value="ma10_deviation_above"><%= t(".cond_ma10_above") %></option>
            <option value="ma20_deviation_below"><%= t(".cond_ma20_below") %></option>
            <option value="ma20_deviation_above"><%= t(".cond_ma20_above") %></option>
            <option value="ma60_deviation_below"><%= t(".cond_ma60_below") %></option>
            <option value="ma60_deviation_above"><%= t(".cond_ma60_above") %></option>
          </select>
        </div>
        <div class="form-field">
          <div class="form-field__header"><label class="form-field__label"><%= t(".name_optional") %></label></div>
          <input type="text" name="market_alert_rule[name]" class="form-field__input" />
        </div>
        <div class="form-field">
          <div class="form-field__header"><label class="form-field__label"><%= t(".threshold_pct") %></label></div>
          <input type="number" name="market_alert_rule[threshold]" placeholder="-5.0" step="0.1" class="form-field__input" required />
        </div>
      </div>
      <button type="submit" class="flex items-center gap-2 px-4 py-2 rounded-lg bg-surface text-white text-sm hover:bg-surface-hover transition-colors">
        <%= icon("plus", size: "sm") %>
        <%= t(".add_rule") %>
      </button>
    <% end %>
  </div>
<% end %>

<%# ── 第三级：触发历史 ─────────────────────────────────────────── %>
<%= settings_section title: t(".history_title"), subtitle: t(".history_subtitle") do %>
  <% if @recent_alerts.any? %>
    <div class="bg-container-inset rounded-xl p-1">
      <div class="bg-container rounded-lg shadow-border-xs divide-y divide-primary">
        <% @recent_alerts.each do |alert| %>
          <div class="flex items-start justify-between px-4 py-3 gap-4">
            <div class="space-y-0.5 min-w-0">
              <p class="text-sm font-medium text-primary truncate"><%= alert.title %></p>
              <p class="text-sm text-secondary"><%= alert.body %></p>
              <p class="text-xs text-tertiary"><%= t(".triggered_at") %>: <%= l(alert.created_at.in_time_zone(Current.user.family.timezone), format: :long) %></p>
            </div>
            <span class="shrink-0 rounded-full px-2.5 py-1 text-xs font-medium <%= alert.sent? ? "bg-green-100 text-green-700" : alert.failed? ? "bg-red-100 text-red-700" : "bg-container-inset text-secondary" %>">
              <%= t(".statuses.#{alert.status}") %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="rounded-xl bg-container-inset p-6">
      <p class="text-sm font-medium text-primary"><%= t(".no_history_title") %></p>
      <p class="text-sm text-secondary mt-1"><%= t(".no_history_body") %></p>
    </div>
  <% end %>
<% end %>
