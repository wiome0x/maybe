<%= content_for :page_title, t(".title") %>

<div class="bg-container shadow-border-xs rounded-xl p-4 grow overflow-y-auto">
  <h2 class="text-lg font-medium text-primary mb-4"><%= t(".title") %></h2>

  <% if @commits.any? %>
    <div class="space-y-1">
      <% @commits.group_by { |c| c[:date].to_date }.each do |date, commits| %>
        <div class="px-3 py-2">
          <p class="text-xs font-medium text-secondary uppercase"><%= I18n.l(date, format: :long) %></p>
        </div>

        <div class="bg-container-inset rounded-lg p-1">
          <% commits.each_with_index do |commit, idx| %>
            <div class="flex items-start gap-3 px-3 py-2.5 bg-container rounded-md shadow-border-xs">
              <div class="shrink-0 mt-0.5">
                <%= icon("git-commit", size: "sm", class: "text-secondary") %>
              </div>

              <div class="flex-1 min-w-0">
                <p class="text-sm text-primary font-medium truncate"><%= commit[:message] %></p>
                <p class="text-xs text-secondary mt-0.5">
                  <%= commit[:author_name] %>
                  <span class="text-subdued">&middot;</span>
                  <code class="text-xs"><%= commit[:short_sha] %></code>
                  <span class="text-subdued">&middot;</span>
                  <%= commit[:date].strftime("%H:%M") %>
                </p>
              </div>
            </div>

            <% if idx < commits.size - 1 %>
              <%= render "shared/ruler" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="flex justify-center items-center py-20">
      <div class="text-center">
        <p class="text-sm text-secondary">No commit history available.</p>
      </div>
    </div>
  <% end %>
</div>
