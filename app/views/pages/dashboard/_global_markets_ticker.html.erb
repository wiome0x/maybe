<div class="bg-container rounded-xl shadow-border-xs p-4 space-y-3" data-controller="global-markets">
  <div class="overflow-x-auto">
    <div class="flex items-center gap-6 text-sm whitespace-nowrap min-w-max">
      <div class="flex items-center gap-1.5 text-secondary shrink-0">
        <%= icon "globe", size: "sm" %>
        <span class="font-medium"><%= t("pages.dashboard.global_markets.title") %></span>
      </div>
      <div data-global-markets-target="indices" class="flex items-center gap-5">
        <span class="text-subdued text-xs">Loading...</span>
      </div>
    </div>
  </div>

  <%= render "shared/ruler" %>

  <div class="overflow-x-auto">
    <div class="flex items-center gap-6 text-sm whitespace-nowrap min-w-max">
      <div class="flex items-center gap-1.5 text-secondary shrink-0">
        <%= icon "clock", size: "sm" %>
        <span class="font-medium"><%= t("pages.dashboard.global_markets.world_time") %></span>
      </div>
      <div class="flex items-center gap-6" data-global-markets-target="clocks"></div>
    </div>
  </div>
</div>
