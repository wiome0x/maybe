<div class="bg-container rounded-xl shadow-border-xs p-4 space-y-3" data-controller="global-markets">
  <div class="flex items-center gap-1.5 text-secondary">
    <%= icon "globe", size: "sm" %>
    <span class="text-sm font-medium"><%= t("pages.dashboard.global_markets.title") %></span>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-2 text-sm" data-global-markets-target="indices">
    <span class="text-subdued text-xs">Loading...</span>
  </div>

  <%= render "shared/ruler" %>

  <div class="flex items-center gap-1.5 text-secondary">
    <%= icon "clock", size: "sm" %>
    <span class="text-sm font-medium"><%= t("pages.dashboard.global_markets.world_time") %></span>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-5 gap-x-6 gap-y-2 text-sm" data-global-markets-target="clocks">
  </div>
</div>
