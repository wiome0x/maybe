<div class="space-y-2" data-controller="global-markets">
  <%# Row 1: Global market indices %>
  <div class="bg-container rounded-xl shadow-border-xs px-4 py-2.5 overflow-x-auto">
    <div class="flex items-center gap-6 text-sm whitespace-nowrap min-w-max">
      <div class="flex items-center gap-1.5 text-secondary shrink-0">
        <%= icon "globe", size: "sm" %>
        <span class="font-medium"><%= t("pages.dashboard.global_markets.title") %></span>
      </div>

      <template data-global-markets-target="indicesTemplate">
        <span class="text-subdued">Loading...</span>
      </template>

      <div data-global-markets-target="indices" class="flex items-center gap-5">
        <span class="text-subdued text-xs">Loading...</span>
      </div>
    </div>
  </div>

  <%# Row 2: Exchange clocks %>
  <div class="bg-container rounded-xl shadow-border-xs px-4 py-2.5">
    <div class="flex items-center justify-between gap-4 text-sm overflow-x-auto">
      <div class="flex items-center gap-2 shrink-0" data-global-markets-target="clock" data-timezone="Asia/Shanghai" data-flag="🇨🇳" data-city="<%= t('pages.dashboard.global_markets.beijing') %>" data-open="09:30" data-close="15:00">
        <span class="text-lg">🇨🇳</span>
        <div>
          <p class="text-primary font-medium" data-global-markets-target="clockTime"></p>
          <p class="text-xs" data-global-markets-target="clockStatus"></p>
        </div>
      </div>

      <div class="flex items-center gap-2 shrink-0" data-global-markets-target="clock" data-timezone="Asia/Tokyo" data-flag="🇯🇵" data-city="<%= t('pages.dashboard.global_markets.tokyo') %>" data-open="09:00" data-close="15:00">
        <span class="text-lg">🇯🇵</span>
        <div>
          <p class="text-primary font-medium" data-global-markets-target="clockTime"></p>
          <p class="text-xs" data-global-markets-target="clockStatus"></p>
        </div>
      </div>

      <div class="flex items-center gap-2 shrink-0" data-global-markets-target="clock" data-timezone="Europe/London" data-flag="🇬🇧" data-city="<%= t('pages.dashboard.global_markets.london') %>" data-open="08:00" data-close="16:30">
        <span class="text-lg">🇬🇧</span>
        <div>
          <p class="text-primary font-medium" data-global-markets-target="clockTime"></p>
          <p class="text-xs" data-global-markets-target="clockStatus"></p>
        </div>
      </div>

      <div class="flex items-center gap-2 shrink-0" data-global-markets-target="clock" data-timezone="Europe/Berlin" data-flag="🇪🇺" data-city="<%= t('pages.dashboard.global_markets.frankfurt') %>" data-open="09:00" data-close="17:30">
        <span class="text-lg">🇪🇺</span>
        <div>
          <p class="text-primary font-medium" data-global-markets-target="clockTime"></p>
          <p class="text-xs" data-global-markets-target="clockStatus"></p>
        </div>
      </div>

      <div class="flex items-center gap-2 shrink-0" data-global-markets-target="clock" data-timezone="America/New_York" data-flag="🇺🇸" data-city="<%= t('pages.dashboard.global_markets.new_york') %>" data-open="09:30" data-close="16:00">
        <span class="text-lg">🇺🇸</span>
        <div>
          <p class="text-primary font-medium" data-global-markets-target="clockTime"></p>
          <p class="text-xs" data-global-markets-target="clockStatus"></p>
        </div>
      </div>
    </div>
  </div>
</div>
