<div class="relative overflow-hidden rounded-[32px] border border-[#2b2b2b] bg-container px-5 py-5 shadow-border-xs md:px-7 md:py-6" data-controller="global-markets">
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-44 bg-[linear-gradient(180deg,rgba(255,255,255,0)_0%,rgba(232,236,250,0.92)_100%)]"></div>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(255,255,255,0.98)_0%,rgba(255,255,255,0.86)_34%,rgba(244,246,252,0.96)_100%)]"></div>
  <div class="pointer-events-none absolute inset-x-[-8%] top-14 h-[82%] rounded-[999px] bg-[radial-gradient(circle_at_center,rgba(227,233,252,0.5)_0%,rgba(238,242,253,0.2)_48%,rgba(255,255,255,0)_76%)] blur-2xl"></div>

  <div class="relative flex items-start justify-between gap-4">
    <div class="space-y-1.5">
      <div class="flex items-center gap-1.5 text-secondary">
        <%= icon "globe", size: "sm" %>
        <span class="text-sm font-medium"><%= t("pages.dashboard.global_markets.title") %></span>
      </div>
      <p class="max-w-[24rem] text-xs leading-5 text-secondary md:text-sm"><%= t("pages.dashboard.global_markets.subtitle") %></p>
    </div>

    <%= link_to market_stocks_path, class: "shrink-0 flex h-14 w-14 items-center justify-center rounded-full border border-tertiary/60 bg-white/90 text-secondary shadow-[0_10px_30px_rgba(17,24,39,0.12)] backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:text-primary" do %>
      <%= icon "external-link", size: "md" %>
    <% end %>
  </div>

  <div class="relative -mx-3 mt-4 min-h-[320px] md:-mx-5 md:mt-2 md:min-h-[440px]">
    <div class="pointer-events-none absolute inset-x-0 top-[6%] bottom-[4%] opacity-[0.97]">
      <%= image_tag "global-markets-map.svg", alt: "", class: "h-full w-full object-contain" %>
    </div>
    <div class="absolute inset-0 pointer-events-none" data-global-markets-target="map"></div>
  </div>
</div>
