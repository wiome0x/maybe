<%# locals: (transaction:, entry: nil) %>

<div id="<%= dom_id(transaction, "category_menu") %>">
  <% if transaction.category.nil? && transaction.funds_movement? && entry.present? %>
    <%= render "categories/badge", category: movement_direction_category(entry) %>
  <% elsif transaction.transfer&.categorizable? || transaction.transfer.nil? %>
    <%= render "categories/menu", transaction: transaction %>
  <% else %>
    <%= render "categories/badge", category: transaction.transfer&.payment? ? payment_category :  transfer_category %>
  <% end %>
</div>
