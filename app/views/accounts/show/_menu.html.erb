<%# locals: (account:) %>

<%= render DS::Menu.new(testid: "account-menu") do |menu| %>
  <% menu.with_item(variant: "link", text: "Edit", href: edit_account_path(account), icon: "pencil-line", data: { turbo_frame: :modal }) %>

  <% unless account.crypto? %>
    <% menu.with_item(
      variant: "link",
      text: "Import transactions",
      href: imports_path({ import: { type: account.investment? ? "TradeImport" : "TransactionImport", account_id: account.id } }),
      icon: "download",
      data: { turbo_frame: :_top }
    ) %>
  <% end %>

  <% if account.linked? %>
    <%
      plaid_item = account.plaid_account&.plaid_item
      is_last_account = plaid_item && plaid_item.accounts.count <= 1
    %>
    <% menu.with_item(
      variant: "button",
      text: is_last_account ? "Delete connection" : "Delete account",
      href: account_path(account),
      method: :delete,
      icon: is_last_account ? "unplug" : "trash-2",
      confirm: CustomConfirm.new(
        title: is_last_account ? "Delete Plaid connection?" : "Delete this account?",
        body: is_last_account ?
          "This will remove the Plaid connection and delete this account along with all its data." :
          "This will delete this account and all its data. The Plaid connection will remain active for your other accounts.",
        btn_text: is_last_account ? "Delete connection" : "Delete account"
      ),
      data: { turbo_frame: :_top }
    ) %>
  <% else %>
    <% menu.with_item(
      variant: "button",
      text: "Delete account",
      href: account_path(account),
      method: :delete,
      icon: "trash-2",
      confirm: CustomConfirm.for_resource_deletion("account", high_severity: true),
      data: { turbo_frame: :_top }
    ) %>
  <% end %>
<% end %>
