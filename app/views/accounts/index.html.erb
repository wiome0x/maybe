<header class="flex justify-between items-center text-primary font-medium">
  <h1 class="text-xl"><%= t(".accounts") %></h1>
  <div class="flex items-center gap-2">
    <%= render DS::Link.new(
      text: "New account",
      href: new_account_path(return_to: accounts_path),
      variant: "primary",
      icon: "plus",
      frame: :modal
    ) %>
  </div>
</header>

<% if @manual_accounts.empty? && @plaid_items.empty? && @draft_accounts.empty? %>
  <%= render "empty" %>
<% else %>
  <div class="space-y-2">
    <% if @plaid_items.any? %>
      <%= render @plaid_items.sort_by(&:created_at) %>
    <% end %>

    <% if @draft_accounts.any? %>
      <%= render "accounts/index/draft_accounts", accounts: @draft_accounts %>
    <% end %>

    <% if @manual_accounts.any? %>
      <%= render "accounts/index/manual_accounts", accounts: @manual_accounts %>
    <% end %>
  </div>

  <%= render "accounts/index/hidden_accounts", accounts: @hidden_accounts %>
<% end %>
