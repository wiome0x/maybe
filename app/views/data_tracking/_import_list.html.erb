<% @imports.each_with_index do |import, idx| %>
  <div class="px-4 py-3 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3 flex-1 min-w-0">
      <div class="shrink-0">
        <%= icon "file-text", size: "sm", class: "text-secondary" %>
      </div>
      <div class="min-w-0">
        <p class="text-sm text-primary truncate">
          <%= import.updated_at.strftime("%b %-d, %Y at %l:%M %p") %>
        </p>
        <div class="flex items-center gap-2 mt-0.5">
          <% if import.complete? %>
            <span class="text-xs text-secondary">
              <%= import.rows.count %> records
              <% if import.respond_to?(:skipped_count) && import.skipped_count.to_i > 0 %>
                · <%= import.skipped_count %> skipped
              <% end %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="shrink-0">
      <% if import.pending? %>
        <span class="px-2 py-0.5 text-xs rounded-full bg-yellow-500/10 text-yellow-600 border border-alpha-black-50">
          Pending
        </span>
      <% elsif import.importing? %>
        <span class="px-2 py-0.5 text-xs rounded-full bg-blue-500/10 text-blue-600 border border-alpha-black-50 animate-pulse">
          Importing
        </span>
      <% elsif import.complete? %>
        <span class="px-2 py-0.5 text-xs rounded-full bg-green-500/10 text-green-600 border border-alpha-black-50">
          Complete
        </span>
      <% elsif import.failed? %>
        <span class="px-2 py-0.5 text-xs rounded-full bg-red-500/10 text-red-600 border border-alpha-black-50">
          Failed
        </span>
      <% end %>
    </div>
  </div>

  <% if idx < @imports.size - 1 %>
    <%= render "shared/ruler" %>
  <% end %>
<% end %>
