<div class="space-y-4">
  <h2 class="text-sm font-medium text-primary"><%= t(".title") %></h2>

  <div class="space-y-4" data-controller="ticker-search">
    <% if @quick_ticker_options.any? %>
      <div class="space-y-2">
        <div class="flex items-center justify-between gap-3">
          <p class="text-xs font-medium uppercase tracking-wide text-secondary"><%= t(".quick_group_title") %></p>
          <p class="text-xs text-secondary"><%= t(".quick_group_subtitle") %></p>
        </div>

        <div class="flex flex-wrap gap-2">
          <% @quick_ticker_options.each do |option| %>
            <button type="button"
                    class="<%= option[:ticker] == @selected_ticker ? 'bg-inverse text-inverse' : 'bg-container-inset text-primary hover:bg-container-inset-hover' %> inline-flex items-center gap-2 rounded-full px-3 py-2 text-sm font-medium"
                    data-action="click->ticker-search#selectTicker"
                    data-ticker="<%= option[:ticker] %>">
              <span><%= option[:ticker] %></span>
              <% if option[:zh_name].present? || option[:en_name].present? %>
                <span class="text-xs opacity-80"><%= [option[:zh_name], option[:en_name]].compact.join(" / ") %></span>
              <% end %>
            </button>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @ticker_options.any? %>
      <div class="space-y-2">
        <div class="flex items-center justify-between gap-3">
          <p class="text-xs font-medium uppercase tracking-wide text-secondary"><%= t(".ticker_list_title") %></p>
          <p class="text-xs text-secondary"><%= t(".ticker_list_subtitle") %></p>
        </div>

        <div class="rounded-xl bg-container-inset p-3">
          <div class="flex flex-wrap gap-2 max-h-40 overflow-y-auto" data-ticker-search-target="list">
            <% @ticker_options.each do |option| %>
              <% search_text = [option[:ticker], option[:en_name], option[:zh_name]].compact.join(" ").downcase %>
              <button type="button"
                      class="<%= option[:ticker] == @selected_ticker ? 'bg-primary text-primary-foreground' : 'bg-container text-primary hover:bg-surface-hover' %> inline-flex items-center gap-2 rounded-full border border-alpha-black-100 px-3 py-1.5 text-sm"
                      data-action="click->ticker-search#selectTicker"
                      data-ticker="<%= option[:ticker] %>"
                      data-search-text="<%= search_text %>"
                      data-ticker-search-target="chip">
                <span class="font-medium"><%= option[:ticker] %></span>
                <% if option[:zh_name].present? %>
                  <span class="text-xs opacity-80"><%= option[:zh_name] %></span>
                <% end %>
                <% if option[:en_name].present? %>
                  <span class="text-xs opacity-80"><%= option[:en_name] %></span>
                <% end %>
              </button>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <div class="flex flex-col sm:flex-row items-end gap-3">
    <div class="form-field w-full sm:w-auto sm:min-w-[200px]">
      <label class="form-field__label" for="ticker_search"><%= t(".ticker") %></label>
      <input type="text"
             id="ticker_search"
             name="ticker"
             placeholder="<%= t(".ticker_placeholder") %>"
             class="form-field__input"
             value="<%= @selected_ticker %>"
             data-action="input->ticker-search#filter"
             data-ticker-search-target="input" />
    </div>

    <div class="form-field w-full sm:w-auto">
      <label class="form-field__label" for="start_date"><%= t(".start_date") %></label>
      <input type="date"
             id="start_date"
             name="start_date"
             class="form-field__input"
             value="<%= @start_date %>"
             data-ticker-search-target="startDate" />
    </div>

    <div class="form-field w-full sm:w-auto">
      <label class="form-field__label" for="end_date"><%= t(".end_date") %></label>
      <input type="date"
             id="end_date"
             name="end_date"
             class="form-field__input"
             value="<%= @end_date %>"
             data-ticker-search-target="endDate" />
    </div>

    <button type="button"
            class="inline-flex items-center gap-1 font-medium whitespace-nowrap rounded-lg px-3 py-2 text-sm text-inverse bg-inverse hover:bg-inverse-hover shrink-0"
            data-action="click->ticker-search#search">
      <%= icon "search", size: "sm", color: "white" %>
      <span><%= t(".search") %></span>
    </button>
    </div>
  </div>

  <%= render "data_tracking/trend" %>
</div>
