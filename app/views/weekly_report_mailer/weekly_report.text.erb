<%= t("settings.weekly_reports.shared.title") %>
<%= @report_presenter.subtitle %>
<%= t("settings.weekly_reports.shared.generated_at") %>: <%= l(@report_presenter.generated_at, format: :long) %>
<%= t("settings.weekly_reports.shared.recipient") %>: <%= @report_presenter.recipient_email %>

<%= t("settings.weekly_reports.shared.overview_title") %>
<% @report_presenter.overview_metrics.each do |metric| %>
- <%= metric[:label] %>: <%= metric[:numeric] == false ? metric[:amount] : format_money(Money.new(metric[:amount].to_d, metric[:currency])) %>
<% end %>
<% if @report_presenter.payload.dig(:overview, :most_active_account).present? %>
<%= t("settings.weekly_reports.shared.most_active_account") %>: <%= @report_presenter.payload.dig(:overview, :most_active_account, :name) %> (<%= format_money(Money.new(@report_presenter.payload.dig(:overview, :most_active_account, :turnover).to_d, @report_presenter.overview_currency)) %>)
<% end %>
<% if @report_presenter.payload.dig(:overview, :top_security).present? %>
<%= t("settings.weekly_reports.shared.top_security") %>: <%= @report_presenter.payload.dig(:overview, :top_security, :ticker) %> · <%= @report_presenter.payload.dig(:overview, :top_security, :name) %> (<%= format_money(Money.new(@report_presenter.payload.dig(:overview, :top_security, :turnover).to_d, @report_presenter.overview_currency)) %>)
<% end %>

<%= t("settings.weekly_reports.shared.accounts_title") %>
<% if @report_presenter.accounts.any? %>
<% @report_presenter.accounts.each do |account| %>

<%= account.name %>
<%= account.subtitle %>
<% account.metrics.each do |metric| %>
- <%= metric[:label] %>: <%= format_money(Money.new(metric[:amount].to_d, account.currency)) %>
<% end %>
<% if account.top_holdings.any? %>
<%= t("settings.weekly_reports.shared.top_holdings_title") %>:
<% account.top_holdings.each do |holding| %>
- <%= holding[:ticker] %> · <%= holding[:name] %> (<%= format_money(Money.new(holding[:amount].to_d, account.currency)) %>, <%= number_to_percentage(holding[:weight], precision: 1) %>)
<% end %>
<% end %>
<% end %>
<% else %>
<%= t("settings.weekly_reports.shared.no_accounts_title") %>
<% end %>

<% if @weekly_report.persisted? %>
<%= t("settings.weekly_reports.shared.history_link") %>: <%= settings_weekly_report_delivery_url(@weekly_report) %>
<% end %>
