# ==========================================
# Maybe Test Environment Example
# Copy to: .env.test (if needed)
# ==========================================

# ==============================
# 1) App Mode / Identity
# ==============================
SELF_HOSTED=false
SELF_HOSTING_ENABLED=false
APP_NAME=Maybe
APP_DOMAIN=maybe.example.com
APP_PROTOCOL=https
APP_PORT=
PORT=3000

# ==============================
# 2) Runtime / Rails
# ==============================
RAILS_ENV=test
NODE_ENV=test
TZ=Asia/Shanghai
RAILS_LOG_TO_STDOUT=false
RAILS_SERVE_STATIC_FILES=true
RAILS_MAX_THREADS=3
# Optional: if you want to pin a test secret instead of relying on Rails defaults.
# SECRET_KEY_BASE=test_secret

# ==============================
# 3) Database / Redis
# ==============================
DB_HOST=127.0.0.1
DB_PORT=5432
POSTGRES_DB=maybe_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_URL=redis://localhost:6379/1

# ==============================
# 4) Sync / Providers
# ==============================
# Only fill these when recording integration fixtures that need live Plaid.
DEV_WEBHOOKS_URL=
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_EU_CLIENT_ID=
PLAID_EU_SECRET=
EXCHANGE_RATE_PROVIDER=
SYNTH_API_KEY=
SYNTH_URL=
FINNHUB_API_KEY=
COINGECKO_API_KEY=

# ==============================
# 5) AI Providers (Optional)
# ==============================
OPENAI_ACCESS_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_MODELS=anthropic/claude-sonnet-4,google/gemini-2.5-flash
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=
AZURE_TRANSLATOR_REGION=

# ==============================
# 6) Email / SMTP
# ==============================
EMAIL_SENDER=
SMTP_ADDRESS=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_ENABLED=true

# ==============================
# 7) Security / Runtime (Optional)
# ==============================
RAILS_FORCE_SSL=false
RAILS_ASSUME_SSL=false
REQUIRE_EMAIL_CONFIRMATION=true
REQUIRE_INVITE_CODE=false
SENTRY_DSN=

# ==============================
# 8) Active Record Encryption (Optional)
# ==============================
# If omitted, the app derives these keys from SECRET_KEY_BASE.
# ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
# ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
# ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ==============================
# 9) Active Storage Configuration
# ==============================
# Defaults to disk storage but you can also use Amazon S3 or Cloudflare R2.
# Ensure libvips is installed for image processing.
#
# ACTIVE_STORAGE_SERVICE=amazon
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_BUCKET=
#
# ACTIVE_STORAGE_SERVICE=cloudflare
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ACCESS_KEY_ID=
# CLOUDFLARE_SECRET_ACCESS_KEY=
# CLOUDFLARE_BUCKET=
