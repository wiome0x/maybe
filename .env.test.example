# ==========================================
# Maybe Test Environment Example
# Copy to: .env.test (if needed)
# ==========================================

# ==============================
# 1) Test Mode / Runtime
# ==============================
SELF_HOSTED=false
RAILS_MAX_THREADS=3
REDIS_URL=redis://localhost:6379/1

# ==============================
# 2) Sync / Plaid (usually optional in tests)
# ==============================
# Only fill these when recording integration fixtures that need live Plaid.
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_EU_CLIENT_ID=
PLAID_EU_SECRET=

# ==============================
# 3) Data Providers (fixture recording)
# ==============================
# Fill live keys only when generating VCR cassette fixtures.
SYNTH_API_KEY=
FINNHUB_API_KEY=
COINGECKO_API_KEY=

# ==============================
# 4) Miscellaneous
# ==============================
# Set true to generate SimpleCov reports.
COVERAGE=false

# Set true to run test suite serially.
DISABLE_PARALLELIZATION=false
