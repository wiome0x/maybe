# ==========================================
# Maybe Local Environment Example
# Copy to: .env.local
# ==========================================

# ==============================
# 1) App Mode / Identity
# ==============================
# Enable self-hosted mode.
SELF_HOSTED=false
# Optional legacy switch. Keep aligned with SELF_HOSTED.
SELF_HOSTING_ENABLED=false

# App display name (Plaid Link / emails / MFA issuer).
APP_NAME=Maybe

# Public domain for production / remote access.
APP_DOMAIN=maybe.example.com
APP_PROTOCOL=https
# Optional. Leave blank if using default 443/80 behind proxy/tunnel.
APP_PORT=

# Puma listens on this port when running locally.
PORT=3000

# ==============================
# 2) Runtime / Rails
# ==============================
RAILS_ENV=development
NODE_ENV=development
TZ=Asia/Shanghai
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
RAILS_MAX_THREADS=3

# If you need to override the default secret locally, generate one with:
# openssl rand -hex 64

# ==============================
# 3) Database / Redis
# ==============================
DB_HOST=localhost
DB_PORT=5432
POSTGRES_DB=maybe_development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Optional. Handy when a single DATABASE_URL is easier than separate DB vars.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/maybe_development

# Redis is required for Sidekiq jobs and async sync processing.
REDIS_URL=redis://redis:6379/1

# ==============================
# 4) Sync / Providers
# ==============================
# In development/non-production, Plaid webhook URL override.
# Example: https://maybe.example.com
# Leave empty in production (app will use APP_DOMAIN-based URL).
DEV_WEBHOOKS_URL=

# Plaid (US)
# development / sandbox / production
PLAID_ENV=development
PLAID_CLIENT_ID=
PLAID_SECRET=

# Plaid (EU, optional)
PLAID_EU_CLIENT_ID=
PLAID_EU_SECRET=

# Market data / rates (optional)
EXCHANGE_RATE_PROVIDER=currency_api
SYNTH_API_KEY=
SYNTH_URL=
FINNHUB_API_KEY=
COINGECKO_API_KEY=

# ==============================
# 5) AI Providers (Optional)
# ==============================
OPENAI_ACCESS_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_MODELS=anthropic/claude-sonnet-4,google/gemini-2.5-flash
# Optional: translate market news headlines in the news tab.
# Only used when the UI locale is Chinese; falls back to original titles if unset.
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=
AZURE_TRANSLATOR_REGION=

# ==============================
# 6) Email / SMTP
# ==============================
EMAIL_SENDER=noreply@example.com
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_ENABLED=true

# ==============================
# 7) Security / Runtime (Optional)
# ==============================
RAILS_FORCE_SSL=true
RAILS_ASSUME_SSL=true
# Signup / invitation policy.
REQUIRE_EMAIL_CONFIRMATION=true
REQUIRE_INVITE_CODE=false
# Optional error tracking.
SENTRY_DSN=

# ==============================
# 8) Active Record Encryption (Optional)
# ==============================
# If omitted, the app derives these keys from SECRET_KEY_BASE.
# ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
# ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
# ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ==============================
# 9) Active Storage Configuration
# ==============================
# Defaults to disk storage but you can also use Amazon S3 or Cloudflare R2.
# Ensure libvips is installed for image processing.
#
# ACTIVE_STORAGE_SERVICE=amazon
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_BUCKET=
#
# ACTIVE_STORAGE_SERVICE=cloudflare
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ACCESS_KEY_ID=
# CLOUDFLARE_SECRET_ACCESS_KEY=
# CLOUDFLARE_BUCKET=
