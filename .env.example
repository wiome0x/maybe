# ================================ PLEASE READ ===========================================================
# This file outlines all the possible environment variables supported by the Maybe app for self hosting.
#
# If you're a developer setting up your local environment, please use `.env.local.example` instead.
# ========================================================================================================

# ==============================
# 1) App Mode / Identity
# ==============================
SELF_HOSTED=true
SELF_HOSTING_ENABLED=true
APP_NAME=Maybe Finance
APP_DOMAIN=
APP_PROTOCOL=https
APP_PORT=
PORT=3000

# ==============================
# 2) Runtime / Rails
# ==============================
RAILS_ENV=production
NODE_ENV=production
TZ=Asia/Shanghai
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
RAILS_MAX_THREADS=3
SECRET_KEY_BASE=secret-value

# ==============================
# 3) Database / Redis
# ==============================
DB_HOST=localhost # May need to be changed to `DB_HOST=db` if using devcontainer
DB_PORT=5432
POSTGRES_DB=maybe
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_URL=redis://localhost:6379/1

# ==============================
# 4) Sync / Providers
# ==============================
DEV_WEBHOOKS_URL=

# Plaid (US)
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=

# Plaid (EU, optional)
PLAID_EU_CLIENT_ID=
PLAID_EU_SECRET=

# Market data / rates (optional)
EXCHANGE_RATE_PROVIDER=
SYNTH_API_KEY=
SYNTH_URL=
FINNHUB_API_KEY=
COINGECKO_API_KEY=

# ==============================
# 5) AI Providers (Optional)
# ==============================
OPENAI_ACCESS_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_MODELS=

# Optional: translate market news headlines in the news tab.
# Only used when the UI locale is Chinese; falls back to original titles if unset.
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=
AZURE_TRANSLATOR_REGION=

# ==============================
# 6) Email / SMTP
# ==============================
SMTP_ADDRESS=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_ENABLED=true
EMAIL_SENDER=

# ==============================
# 7) Security / Runtime (Optional)
# ==============================
RAILS_FORCE_SSL=true
RAILS_ASSUME_SSL=true
REQUIRE_EMAIL_CONFIRMATION=true
REQUIRE_INVITE_CODE=false
SENTRY_DSN=

# ==============================
# 8) Active Record Encryption (Optional)
# ==============================
# If omitted, the app derives these keys from SECRET_KEY_BASE.
# ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
# ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
# ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ==============================
# 9) Active Storage Configuration
# ==============================
# Defaults to disk storage but you can also use Amazon S3 or Cloudflare R2.
# Ensure libvips is installed for image processing.
#
# ACTIVE_STORAGE_SERVICE=amazon
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_BUCKET=
#
# ACTIVE_STORAGE_SERVICE=cloudflare
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ACCESS_KEY_ID=
# CLOUDFLARE_SECRET_ACCESS_KEY=
# CLOUDFLARE_BUCKET=

